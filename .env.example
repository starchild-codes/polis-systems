# Supabase project settings
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Twilio webhook configuration. Never prefix these with VITE_.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+1XXXXXXXXXX
# Optional approved Twilio Content Template for business-initiated assignments.
TWILIO_TASK_ASSIGNMENT_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional approved templates for review outcomes outside the 24-hour window.
TWILIO_REVIEW_APPROVED_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_REVIEW_REJECTED_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional server-only cap. Values above 10 MiB are reduced to the safe default.
WHATSAPP_MEDIA_MAX_BYTES=10485760
